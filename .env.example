# ──────────────── Telegram ────────────────
BOT_TOKEN=123456:ABC-DEF
BOT_USERNAME=vpnbox_bot
ADMIN_ID=123456789

# ──────────────── Database ────────────────
DATABASE_URL=postgresql+asyncpg://vpnbox:ПАРОЛЬ@localhost:5432/vpnbox

# ──────────────── Redis ────────────────
REDIS_URL=redis://localhost:6379/0

# ──────────────── YooKassa ────────────────
YOOKASSA_SHOP_ID=000000
YOOKASSA_SECRET_KEY=test_XXXXXXXXXXXX

# ──────────────── FreeKassa ────────────────
FREEKASSA_SHOP_ID=000000
FREEKASSA_SECRET1=secret_word_1
FREEKASSA_SECRET2=secret_word_2
FREEKASSA_API_KEY=api_key_here
FREEKASSA_PAYMENT_SYSTEM_ID=0

# ──────────────── Platega ────────────────
PLATEGA_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PLATEGA_SECRET_KEY=your_secret_key_here
PLATEGA_PAYMENT_METHOD=10  # 2=SBP, 10=CardRu/МИР, 12=International

# ──────────────── CryptoCloud ────────────────
CRYPTOCLOUD_SHOP_ID=your_shop_id_here
CRYPTOCLOUD_API_KEY=your_api_key_here

# ──────────────── Telegram Stars ────────────────
# Ключи не нужны — Stars всегда включён автоматически.

# ──────────────── VPN Servers (JSON) ────────────────
# panel_type: "3xui"
VPN_SERVERS=[{"id":1,"name":"Нидерланды","panel_type":"3xui","url":"http://localhost:2053","username":"admin","password":"admin","country":"🇳🇱","inbound_id":1,"max_users":500}]
LOG_LEVEL=DEBUG